{
  "expo": {
    "name": "expo-sudoku-app",
    "slug": "expo-sudoku-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon/adaptive-iconv2.png",
    "scheme": "exposudokuapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.exposudokuapp",
      "icon": {
        "light": "./assets/images/splash/sudoku_icon_v2.png",
        "dark": "./assets/images/splash/sudoku_icon_v2.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon/adaptive-iconv2.png",
        "backgroundColor": "#0D0D1B"
      },
      "package": "com.anonymous.exposudokuapp",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D0D1B",
          "image": "./assets/images/splash/sudoku_icon_v2.png",
          "dark": {
            "image": "./assets/images/splash/sudoku_icon_v2.png",
            "backgroundColor": "#0D0D1B"
          },
          "imageWidth": 120
        }
      ],
      "expo-sqlite",
      "expo-audio",
      "expo-web-browser",
      "expo-font",
      "expo-image",
      "expo-sharing",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bf2fef7a-67c6-4752-96c5-489e66f9c080"
      }
    }
  }
}
